# =========================
# MODE
# =========================
# TEST  -> bypasses schedule restrictions for development
# PROD  -> enforces normal execution rules

MODE=PROD


# =========================
# DAILY SEND WINDOW
# =========================
# If enabled, the app should send only once within this window,
# choosing a random time between start and end.

SEND_WINDOW_ENABLED=true
SEND_WINDOW_START=08:30
SEND_WINDOW_END=09:30


# =========================
# WHATSAPP WEB / SELENIUM
# =========================

# Path to Chrome user data directory or local persisted profile folder
CHROME_PROFILE_PATH=chrome_profile

# Chrome profile directory name
# Examples: Default, Profile 1
CHROME_PROFILE_DIRECTORY=Default

# WhatsApp Web base URL
WHATSAPP_WEB_URL=https://web.whatsapp.com/

# Run browser in background (true/false)
HEADLESS=false

# If headless fails, retry automatically in visible mode
ENABLE_HEADLESS_FALLBACK=true

# Enable random human-like delays
USE_RANDOM_DELAY=true

# Destination number in numeric format only
# Example: 554199887766
DESTINATION_PHONE=554199887766

# Optional: explicit path to chromedriver
# Leave empty to use Selenium Manager / system resolution
CHROMEDRIVER_PATH=


# =========================
# MESSAGE FILES (PRIVATE)
# =========================
# These files contain your personal messages
# They should NOT be committed to Git

GREETINGS_FILE=config/greetings_private.txt
MESSAGES_FILE=config/messages_private.txt


# =========================
# DELAYS
# =========================
# Random delays to simulate natural interaction

# Delay after opening WhatsApp
MIN_OPEN_DELAY_SECONDS=2
MAX_OPEN_DELAY_SECONDS=4

# Delay before sending message
MIN_PRE_SEND_DELAY_SECONDS=2
MAX_PRE_SEND_DELAY_SECONDS=4

# Delay after sending message
MIN_POST_SEND_DELAY_SECONDS=2
MAX_POST_SEND_DELAY_SECONDS=4


# =========================
# TIMEOUTS
# =========================

LOGIN_TIMEOUT_SECONDS=120
ELEMENT_TIMEOUT_SECONDS=60
PAGE_LOAD_TIMEOUT_SECONDS=60
SCRIPT_TIMEOUT_SECONDS=60


# =========================
# RETRY CONFIG
# =========================

MAX_RETRIES=2
RETRY_DELAY_SECONDS=5