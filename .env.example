# =========================
# MODE
# =========================
# Options:
# TEST → bypasses schedule restrictions for development
# PROD → enforces normal execution rules

MODE=TEST


# =========================
# SENDER MODE
# =========================
# Choose how the message will be sent
# Options:
# selenium → sends using your personal WhatsApp via browser (recommended)
# twilio   → sends via Twilio API (will NOT appear as your number)

SENDER_MODE=selenium


# =========================
# TWILIO WHATSAPP NUMBERS
# =========================
# Used when SENDER_MODE=twilio

# Twilio sender number
# Example (Sandbox): +14155238886

TWILIO_WHATSAPP_NUMBER=+14155238886

# Destination number that will receive the message
# Example: +554199887766

MY_WHATSAPP_NUMBER=+554199887766


# =========================
# TWILIO
# =========================
# Only required if SENDER_MODE=twilio

# Your Twilio Account SID and Twilio Auth Token
TWILIO_SID=
TWILIO_TOKEN=


# =========================
# SELENIUM / WHATSAPP WEB
# =========================
# Used when SENDER_MODE=selenium

# Path to Chrome session (keeps you logged in)
# Example: chrome_profile

CHROME_PROFILE_PATH=chrome_profile

# WhatsApp Web base URL (do not change)

WHATSAPP_WEB_URL=https://web.whatsapp.com/

# Run browser in background (true/false)
# false → visible (recommended for testing)
# true  → headless mode (advanced)

HEADLESS=false

# Destination number in numeric format only
# Example: 5541999999999

DESTINATION_PHONE=5541999999999


# =========================
# MESSAGE FILES (PRIVATE)
# =========================
# These files contain your personal messages
# They should NOT be committed to Git

# Examples:
# config/greetings_private.txt
# config/messages_private.txt

GREETINGS_FILE=config/greetings_private.txt
MESSAGES_FILE=config/messages_private.txt


# =========================
# DELAYS
# =========================
# Random delays to simulate natural interaction

# Delay after opening WhatsApp
MIN_OPEN_DELAY_SECONDS=2
MAX_OPEN_DELAY_SECONDS=5

# Delay before sending message
MIN_PRE_SEND_DELAY_SECONDS=3
MAX_PRE_SEND_DELAY_SECONDS=7

# Delay after sending message
MIN_POST_SEND_DELAY_SECONDS=2
MAX_POST_SEND_DELAY_SECONDS=4


# =========================
# TIMEOUTS
# =========================
# Maximum time to wait for elements

LOGIN_TIMEOUT_SECONDS=120
ELEMENT_TIMEOUT_SECONDS=60


# =========================
# RETRY CONFIG
# =========================
# Number of retries if sending fails

MAX_RETRIES=2
RETRY_DELAY_SECONDS=5